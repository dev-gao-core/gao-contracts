# GaoDomainDeposit deploy-time configuration. Copy to `.env` and fill
# in. NEVER commit `.env`. NEVER paste real values into chat.

# ── Required ────────────────────────────────────────────────────────────────

# Hot deploy wallet — funded with a small amount of native gas (Base
# Sepolia ETH for testnet; Base ETH for mainnet). Production deploys
# SHOULD transfer ownership to a multisig immediately after deploy
# (see GAO_OWNER_ADDRESS below).
DEPLOYER_PRIVATE_KEY=

# RPC endpoints. Use a private endpoint with an API key, NOT a public
# rate-limited one. Different keys for staging vs production.
BASE_SEPOLIA_RPC_URL=
BASE_RPC_URL=

# ── Optional ────────────────────────────────────────────────────────────────

# Final owner of the deployed contract. Defaults to the deployer
# wallet. Production: set this to a Safe multisig and the deploy
# script will transfer ownership in the constructor — the deployer
# never has admin rights post-deploy.
GAO_OWNER_ADDRESS=

# Wallet that receives `withdrawTreasury` sweeps (settled USDC). Distinct
# from GAO_OWNER_ADDRESS so the controller multisig can be separate from
# the revenue-receiving wallet. Defaults to GAO_OWNER_ADDRESS / deployer
# if unset. Required non-zero by the constructor.
GAO_TREASURY_ADDRESS=

# When set, the deploy script calls setAllowedToken(USDC, true) in a
# follow-up tx so the contract is immediately depositable. Skip it to
# do this manually from the multisig later.
GAO_USDC_ADDRESS=

# Etherscan-format API key for `npx hardhat verify`. One key works for
# both Base + Base Sepolia under the unified Etherscan v2 API.
BASESCAN_API_KEY=
